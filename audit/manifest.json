  "known_bugs": [
    {
      "id": "B1",
      "title": "Custom DB tables never created",
      "detail": "BP_Share_Post_Type_Tracker listens on bp_share_activate hook, but that hook is never fired anywhere. activate_buddypress_share_pro() calls Buddypress_Share_Activator::activate() which never calls do_action('bp_share_activate'). Post-type tracking table and settings table silently do not exist.",
      "file": "includes/post-types/class-bp-share-post-type-tracker.php:44 + includes/class-buddypress-share-activator.php",
      "severity": "blocker"
    },
    {
      "id": "B2",
      "title": "Cron cleanup callback not wired",
      "detail": "bp_share_weekly_cleanup cron event scheduled on activation (activator:289) but no add_action hooking Buddypress_Share_Activator::cleanup_orphaned_data to it. Cleanup never runs.",
      "file": "includes/class-buddypress-share-activator.php:289-293",
      "severity": "major"
    },
    {
      "id": "B3",
      "title": "Bluesky icon class invalid in FA 5",
      "detail": "'fas fa-bluesky' does not exist in Font Awesome 5.15.4. Bluesky was added to FA 6.6+. The icon will render as nothing or blank on all installs.",
      "files": ["public/class-buddypress-share-public.php:703", "includes/post-types/class-bp-share-post-type-settings.php:89"],
      "severity": "major"
    },
    {
      "id": "B4",
      "title": "post-type AJAX uses wp_die(json_encode()) instead of wp_send_json_*",
      "detail": "handle_ajax_share() uses wp_die(json_encode(...)) instead of wp_send_json_success/wp_send_json_error. Does not set JSON content-type header, breaks native WP AJAX JSON handling.",
      "file": "includes/post-types/class-bp-share-post-type-controller.php:245-297",
      "severity": "major"
    },
    {
      "id": "B5",
      "title": "User ID exposed in public share URLs",
      "detail": "bps_uid (logged-in user ID) appended to every share link URL. Anyone who receives a share link can identify which user shared it. GDPR/privacy concern.",
      "files": ["public/class-buddypress-share-public.php:765", "includes/post-types/class-bp-share-post-type-controller.php:452"],
      "severity": "major"
    },
    {
      "id": "B6",
      "title": "uninstall.php contains no cleanup logic",
      "detail": "uninstall.php only contains the WP_UNINSTALL_PLUGIN guard and nothing else. Custom tables, options, user meta, activity meta are all orphaned on uninstall. WordPress.org requires uninstall cleanup.",
      "file": "uninstall.php",
      "severity": "major"
    },
    {
      "id": "B7",
      "title": "get_option vs get_site_option inconsistency for bpas_icon_color_settings",
      "detail": "Activator sets this via update_site_option. Admin reads via get_option. Public reads via get_option. This means on non-multisite the values match, but on multisite the activator sets it network-wide while the readers pull the site-level value. Inconsistent defaults on multisite.",
      "files": ["includes/class-buddypress-share-activator.php:94", "admin/class-buddypress-share-admin.php:745", "public/class-buddypress-share-public.php:387"],
      "severity": "minor"
    },
    {
      "id": "B8",
      "title": "CDN dependencies violate WordPress.org guidelines",
      "detail": "Bootstrap 4.6.2 CSS/JS and Select2 4.1.0-rc.0 are loaded from cdnjs.cloudflare.com on every BP page. WordPress.org submission rules require all assets to be bundled locally. Site also breaks in air-gapped/offline environments.",
      "files": ["public/class-buddypress-share-public.php:62-67"],
      "severity": "major"
    },
    {
      "id": "B9",
      "title": "Version constant mismatch: CLAUDE.md says 2.1.0, plugin says 2.2.4",
      "detail": "CLAUDE.md Quick Reference lists version 2.1.0 but buddypress-share.php header and BP_ACTIVITY_SHARE_PLUGIN_VERSION both declare 2.2.4. Documentation out of sync.",
      "files": ["CLAUDE.md:5", "buddypress-share.php:16,32"],
      "severity": "minor"
    },
    {
      "id": "B10",
      "title": "Post type sharing enabled by default (filter default true) without guard",
      "detail": "init_post_type_sharing() calls BP_Share_Post_Type_Controller::get_instance() unconditionally (filter defaults to true). The subsystem activates even when the custom tables don't exist, causing silent DB failures on every post-type share attempt.",
      "file": "includes/class-buddypress-share.php:313",
      "severity": "major"
    }
  ]
}
